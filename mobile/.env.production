# Production (race day): phone and PC both on the 'LineFollower' ESP32 AP.
# Update EXPO_PUBLIC_BACKEND_BASE_URL to the PC's 192.168.4.x IP (check with ipconfig).
EXPO_PUBLIC_BACKEND_BASE_URL=http://192.168.4.2:3001
EXPO_PUBLIC_ESP32_WS_URL=ws://192.168.4.1/ws
EXPO_PUBLIC_DRIVE_INTERVAL_MS=50
EXPO_PUBLIC_DEV_MODE=false
