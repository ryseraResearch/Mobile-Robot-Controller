# Development: DEV_MODE bypasses backend and ESP32 — runs with console logs only.
# Backend URL is still set in case you want to test against a local server.
EXPO_PUBLIC_BACKEND_BASE_URL=http://192.168.4.2:3001
EXPO_PUBLIC_ESP32_WS_URL=ws://192.168.4.1/ws
EXPO_PUBLIC_DRIVE_INTERVAL_MS=50
EXPO_PUBLIC_DEV_MODE=true
