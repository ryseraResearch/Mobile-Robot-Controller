# Production: admin and backend both on the ESP32 AP (192.168.4.x).
# Update VITE_BACKEND_BASE_URL / VITE_BACKEND_WS_URL to the PC's actual
# 192.168.4.x IP after connecting to the 'LineFollower' AP (check with ipconfig).
VITE_BACKEND_BASE_URL=http://192.168.4.2:3001
VITE_BACKEND_WS_URL=ws://192.168.4.2:3001/ws
VITE_ESP32_WS_URL=ws://192.168.4.1/ws
